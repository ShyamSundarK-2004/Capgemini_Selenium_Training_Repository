package com.webEleementInterrogationMethods;

import java.io.File;
import java.io.IOException;
import java.nio.file.Files;
import java.time.Duration;
import java.util.logging.FileHandler;

import org.openqa.selenium.By;
import org.openqa.selenium.OutputType;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;

public class Verification_getSize {

	public static void main(String[] args) throws InterruptedException, IOException {
		WebDriver driver = new ChromeDriver();
		driver.manage().window().maximize();
		driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(20));
		driver.navigate().to("https://www.selenium.dev/");
		Thread.sleep(2000);

		// fetching both height and width of a element
		System.out.println(
				driver.findElement(By.xpath("//div[@class='col-lg-4 mb-5 mb-lg-0 text-center bg-transparent'][3]"))
						.getSize());

		// fetching height using final height variabel or use getheight()
		System.out.println(
				driver.findElement(By.xpath("//div[@class='col-lg-4 mb-5 mb-lg-0 text-center bg-transparent'][3]"))
						.getSize().height);
		// fetching width using width final variable or use getwidth()
		System.out.println(
				driver.findElement(By.xpath("//div[@class='col-lg-4 mb-5 mb-lg-0 text-center bg-transparent'][3]"))
						.getSize().getWidth());

		WebElement element = driver
				.findElement(By.xpath("//div[@class='col-lg-4 mb-5 mb-lg-0 text-center bg-transparent'][3]"));

		File src = element.getScreenshotAs(OutputType.FILE);
		File f = new File("C:\\Users\\Shyam Sundar\\OneDrive\\Desktop\\Automation Testing Capg");
		org.openqa.selenium.io.FileHandler.copy(src, f);
		driver.quit();

	}
}
