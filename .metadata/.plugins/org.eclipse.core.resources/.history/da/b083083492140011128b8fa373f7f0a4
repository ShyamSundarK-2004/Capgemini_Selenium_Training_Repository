package com.selenium.attributes;

import org.openqa.selenium.chrome.ChromeDriver;

public class XpathByAttributes_Example {

	public static void main(String[] args) throws InterruptedException {

		WebDriver driver = new ChromeDriver();
		driver.manage().window().maximize();

		// 1. Amazon Search Box
		driver.get("https://www.amazon.in/");
		Thread.sleep(2000);
		driver.findElement(By.xpath("//input[@id='twotabsearchtextbox']")).sendKeys("Mobile");
		Thread.sleep(2000);

		// 2. Facebook Email
		driver.get("https://www.facebook.com/");
		Thread.sleep(2000);
		driver.findElement(By.xpath("//input[@name='email']")).sendKeys("test@gmail.com");
		Thread.sleep(2000);

		// 3. LinkedIn Username
		driver.get("https://www.linkedin.com/");
		Thread.sleep(2000);
		driver.findElement(By.xpath(
				"//a[@class='sign-in-form__sign-in-cta my-2 py-1 btn-md btn-secondary block min-h-[40px] babybear:w-full']"))
				.click();
		Thread.sleep(2000);

		// 4. Wikipedia Search
		driver.get("https://www.wikipedia.org/");
		Thread.sleep(2000);
		driver.findElement(By.xpath("//input[@id='searchInput']")).sendKeys("India");
		Thread.sleep(2000);

		// 5. YouTube Search
		driver.get("https://www.youtube.com/");
		Thread.sleep(2000);
		driver.findElement(By.xpath("//input[@name='search_query']")).sendKeys("Selenium");
		Thread.sleep(2000);

		driver.quit();
	}
}