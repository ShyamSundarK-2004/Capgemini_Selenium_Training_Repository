package com.webEleementInterrogationMethods;

import java.time.Duration;

import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.chrome.ChromeDriver;

public class Verification_getSize {

	public static void main(String[] args) throws InterruptedException {
		WebDriver driver = new ChromeDriver();
		driver.manage().window().maximize();
		driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(20));
		driver.navigate().to("https://www.selenium.dev/");
		Thread.sleep(2000);

		System.out.println(driver.findElement(By.xpath("//span//*[1]")).getCssValue("margin"));
		System.out.println(driver.findElement(By.xpath("//span//*[1]")).getCssValue("display"));
		System.out.println(driver.findElement(By.xpath("//span//*[1]")).getCssValue("font-weight"));
		System.out.println(driver.findElement(By.xpath("//span//*[1]")).getCssValue("overflow"));
		System.out.println(driver.findElement(By.xpath("//span//*[1]")).getCssValue("font-family"));

		driver.quit();

	}
}
