package com.webEleementInterrogationMethods;

import java.time.Duration;

import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.chrome.ChromeDriver;

public class Verification_isEnabled {
	public static void main(String[] args) throws InterruptedException {
		WebDriver driver = new ChromeDriver();
		driver.manage().window().maximize();
		driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(20));
		driver.navigate().to("https://demoapps.qspiders.com/ui?scenario=1");
		Thread.sleep(2000);

		// check if the button is enabled
		System.out.println(driver.findElement(By.xpath("//button[@type='submit']")).isEnabled());

		driver.navigate().to("https://www.shoppersstack.com/products_page/34");
		System.out.println("is button enabled" + driver.findElement(By.xpath("//button[@id=\"Check\"]")).isEnabled());

		driver.quit();
	}

}
