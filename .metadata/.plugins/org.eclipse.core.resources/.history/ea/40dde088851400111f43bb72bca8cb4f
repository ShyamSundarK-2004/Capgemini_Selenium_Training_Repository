package com.manageMethods;

import org.openqa.selenium.Dimension;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.chrome.ChromeDriver;

public class Wedriver_manageMethod {

	public static void main(String[] args) throws InterruptedException {

		WebDriver driver = new ChromeDriver(); // launch chrome browser

		Thread.sleep(2000);
		driver.manage().window().maximize(); // maximize browser window

		Thread.sleep(2000);
		driver.manage().window().minimize(); // minimize browser window

		Thread.sleep(2000);
		driver.manage().window().fullscreen(); // open full screen

		Thread.sleep(2000);
		System.out.println(driver.manage().window().getSize()); // get window size

		Thread.sleep(2000);
		driver.manage().window().setSize(new Dimension(1024, 900)); // set window size

		Thread.sleep(2000);
		System.out.println(driver.manage().window().getPosition()); // get window position

		Thread.sleep(2000);
		driver.manage().window().setPosition(new Point(15, 15)); // set window position

		Thread.sleep(2000);
		driver.quit(); // close browser

	}
}
